LOG_LEVEL=info

# SQLite database path. Use :memory: for throwaway tests.
# 安装包模式下，install.sh 会默认把它写成 ~/.local/share/opencode-feishu-imui/imui.db
IMUI_DB_PATH=.data/imui.db

# Optional runtime directories.
IMUI_CONFIG_DIR=
IMUI_DATA_DIR=
IMUI_ASSET_CACHE_DIR=
IMUI_BACKUP_DIR=

# Optional runtime retention knobs.
IMUI_ASSET_TTL_HOURS=168
IMUI_ASSET_MAX_MB=1024
IMUI_BACKUP_RETENTION_DAYS=14

# stdin: local NDJSON loop for development
# long_conn: real Feishu long connection mode
# off: disable inbound events entirely
FEISHU_MODE=stdin
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional. Recommended in group chats so first-message @bot detection is stable.
FEISHU_BOT_OPEN_ID=

# Default OpenCode server connection.
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=

# Default directory / workspace / agent / model used for new sessions.
# Prefer absolute paths for OPENCODE_DIRECTORY.
# OPENCODE_MODEL format: <provider>/<model_id>[@<variant>]
OPENCODE_DIRECTORY=
OPENCODE_WORKSPACE=
OPENCODE_AGENT=
OPENCODE_MODEL=

# Optional runtime override.
# You can also pass: opencode-feishu-imui --env-file /path/to/.env
# IMUI_ENV_FILE=
